# Expo client env (safe to expose in app bundle)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# Optional alias used by some setups:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here

# R2 + Edge Function secrets (DO NOT prefix with EXPO_PUBLIC)
# For deployed functions, set these with:
# supabase secrets set KEY=value ...
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=exercise-media
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BASE_URL=https://your-public-r2-base-url
R2_S3_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
