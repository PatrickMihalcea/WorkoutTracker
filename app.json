{
  "expo": {
    "name": "Setora",
    "slug": "workout-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Setora.png",
    "userInterfaceStyle": "dark",
    "scheme": "workout-tracker",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Setora.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patrickmihalcea.workouttracker",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Setora uses notifications for rest timers and daily workout reminders.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "icon": "./assets/Setora.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Setora.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.patrickmihalcea.workouttracker"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Setora uses your photos so you can choose exercise images.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "revenueCat": {
        "entitlementId": "Setora Pro",
        "offeringId": "default",
        "useTestStore": false,
        "testApiKey": "test_hzdPRMAnYFruOAwFIvSERdteFhs",
        "iosApiKey": "appl_CZOTxOHzXTTtQrQSeuhhGAzisod",
        "androidApiKey": "goog_ngeznkiHxoMCibdwyfXzypOTxus"
      },
      "eas": {
        "projectId": "fc602efb-0f30-4edc-aece-e9663e734d6a"
      }
    }
  }
}
