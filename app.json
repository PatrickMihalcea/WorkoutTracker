{
  "expo": {
    "name": "Setora",
    "slug": "workout-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Setora.png",
    "userInterfaceStyle": "dark",
    "scheme": "workout-tracker",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.patrickmihalcea.workouttracker",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Setora uses notifications for rest timers and daily workout reminders.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Setora.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.patrickmihalcea.workouttracker"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc602efb-0f30-4edc-aece-e9663e734d6a"
      }
    }
  }
}
